---
import "../styles/global.css";
import NavBar from "../components/ui/NavBar.astro";
import { Font } from "astro:assets";
import { getAbsoluteLocaleUrl } from "astro:i18n";
import type { Locale } from "@/i18n/translations";

interface Props {
  title: string;
  description: string;
  locale: Locale;
}

const { title, description, locale } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(`/og/${locale}.png`, Astro.site);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="description" content={description} />

    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="en" href={getAbsoluteLocaleUrl("en", "")} />
    <link rel="alternate" hreflang="es" href={getAbsoluteLocaleUrl("es", "")} />
    <link
      rel="alternate"
      hreflang="x-default"
      href={getAbsoluteLocaleUrl("en", "")}
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:locale" content={locale === "es" ? "es_AR" : "en_US"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Self-hosted fonts via Astro Fonts API -->
    <Font cssVariable="--font-sans" preload />
    <Font cssVariable="--font-mono" />

    <title>{title}</title>
  </head>
  <body>
    <NavBar locale={locale} />
    <main>
      <slot />
    </main>

    <script is:inline>
      (function () {
        const revealObserver = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("visible");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1 },
        );

        document.querySelectorAll(".reveal").forEach(function (element) {
          revealObserver.observe(element);
        });
      })();
    </script>
    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "5acaa40a6cf84bc183dc2365434d6591"}'
    ></script><!-- End Cloudflare Web Analytics -->
  </body>
</html>
