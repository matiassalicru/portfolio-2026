---
import { contactLinks } from '../../data/contact'
import type { Locale } from '@/i18n/translations'
import { getTranslations } from '@/i18n/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const translations = getTranslations(locale)
---

<section
  id="contact"
  style="padding: 6rem 1.5rem 8rem; max-width: 1024px; margin: 0 auto;"
>
  <div class="reveal">
    <h2
      style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin: 0 0 1rem;"
    >
      {translations.contact.sectionLabel}
    </h2>
    <h3
      style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--color-text); margin: 0 0 0.75rem; letter-spacing: -0.02em;"
    >
      {translations.contact.heading}
    </h3>
    <p
      style="font-size: 1rem; color: var(--color-muted); line-height: 1.75; margin: 0 0 2.5rem; max-width: 480px;"
    >
      {translations.contact.body}
    </p>

    <div style="display: flex; flex-direction: column; gap: 0.875rem;">
      {
        contactLinks.map((link) => (
          <a
            href={link.href}
            target={link.icon !== 'email' ? '_blank' : undefined}
            rel={link.icon !== 'email' ? 'noopener noreferrer' : undefined}
            style="display: inline-flex; align-items: center; gap: 0.875rem; padding: 1rem 1.5rem; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.625rem; text-decoration: none; color: var(--color-text); font-size: 0.9rem; font-weight: 500; transition: border-color 0.2s ease; max-width: 420px;"
            onmouseover="this.style.borderColor='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border)'"
          >
            <!-- Email icon -->
            {link.icon === 'email' && (
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-accent)"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            )}
            <!-- LinkedIn icon -->
            {link.icon === 'linkedin' && (
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-accent)"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect x="2" y="9" width="4" height="12" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            )}
            <!-- GitHub icon -->
            {link.icon === 'github' && (
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="var(--color-accent)"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
            )}
            <span style="color: var(--color-muted);">{link.label}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
