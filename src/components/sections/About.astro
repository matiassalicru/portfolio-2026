---
import type { Locale } from '@/i18n/translations'
import { getTranslations } from '@/i18n/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const translations = getTranslations(locale)
---

<section
  id="about"
  style="padding: 6rem 1.5rem; max-width: 1024px; margin: 0 auto;"
>
  <div class="reveal">
    <h2
      style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin: 0 0 1rem;"
    >
      {translations.about.sectionLabel}
    </h2>
    <div
      style="display: grid; grid-template-columns: 1fr; gap: 2.5rem; max-width: 720px;"
    >
      <div style="display: flex; flex-direction: column; gap: 1.25rem;">
        <h3
          style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.2; letter-spacing: -0.02em;"
        >
          {translations.about.heading}
        </h3>
        <p
          style="font-size: 1rem; color: var(--color-muted); line-height: 1.75; margin: 0;"
        >
          {translations.about.p1}
        </p>
        <p
          style="font-size: 1rem; color: var(--color-muted); line-height: 1.75; margin: 0;"
        >
          {translations.about.p2}
        </p>
        <p
          style="font-size: 1rem; color: var(--color-muted); line-height: 1.75; margin: 0;"
        >
          {translations.about.p3}
        </p>
      </div>
    </div>
  </div>
</section>
