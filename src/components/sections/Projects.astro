---
import { projects } from '../../data/projects'
import type { Locale } from '@/i18n/translations'
import { getTranslations } from '@/i18n/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const translations = getTranslations(locale)

const projectDescriptions: Record<string, string> = {
  swyd: translations.projects.swyd.description,
  swiftTodoApp: translations.projects.swiftTodoApp.description,
  dashboard: translations.projects.dashboard.description,
}

const slugByName: Record<string, string> = {
  swyd: 'swyd',
  'Swift-todo-app': 'swiftTodoApp',
  dashboard: 'dashboard',
}
---

<section
  id="projects"
  style="padding: 6rem 1.5rem; max-width: 1024px; margin: 0 auto;"
>
  <h2
    style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin: 0 0 1rem;"
  >
    {translations.projects.sectionLabel}
  </h2>
  <h3
    style="font-size: clamp(1.75rem, 4vw, 2.5rem); font-weight: 700; color: var(--color-text); margin: 0 0 3rem; letter-spacing: -0.02em;"
  >
    {translations.projects.heading}
  </h3>

  <div
    style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;"
  >
    {
      projects.map((project) => {
        const slug = slugByName[project.name]
        const description = projectDescriptions[slug] ?? ''

        return (
          <div
            class="reveal"
            style="display: flex; flex-direction: column; background-color: var(--color-surface); border: 1px solid var(--color-border); border-radius: 0.75rem; padding: 1.5rem; gap: 1rem; transition: border-color 0.2s ease;"
            onmouseover="this.style.borderColor='var(--color-accent)'"
            onmouseout="this.style.borderColor='var(--color-border)'"
          >
            <div style="display: flex; align-items: flex-start; justify-content: space-between; gap: 0.75rem;">
              <h4
                style="font-size: 1rem; font-weight: 600; color: var(--color-text); margin: 0; letter-spacing: -0.01em;"
              >
                {project.name}
              </h4>
              <span
                style="flex-shrink: 0; font-size: 0.7rem; font-weight: 600; font-family: var(--font-mono), monospace; color: var(--color-accent); background-color: rgba(168, 85, 247, 0.1); border: 1px solid rgba(168, 85, 247, 0.25); border-radius: 0.25rem; padding: 0.125rem 0.5rem;"
              >
                {project.lang}
              </span>
            </div>

            <p
              style="font-size: 0.875rem; color: var(--color-muted); line-height: 1.65; margin: 0; flex: 1;"
            >
              {description}
            </p>

            <div style="display: flex; flex-wrap: wrap; gap: 0.375rem;">
              {project.tags.map((tag) => (
                <span
                  style="font-size: 0.7rem; font-weight: 500; color: var(--color-muted); background-color: rgba(255, 255, 255, 0.04); border: 1px solid var(--color-border); border-radius: 0.25rem; padding: 0.125rem 0.5rem;"
                >
                  {tag}
                </span>
              ))}
            </div>

            <a
              href={project.repo}
              target="_blank"
              rel="noopener noreferrer"
              style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; background-color: transparent; border: 1px solid var(--color-border); border-radius: 0.5rem; text-decoration: none; color: var(--color-muted); font-size: 0.8rem; font-weight: 500; transition: border-color 0.2s ease, color 0.2s ease; margin-top: auto;"
              onmouseover="this.style.borderColor='var(--color-accent)'; this.style.color='var(--color-text)'"
              onmouseout="this.style.borderColor='var(--color-border)'; this.style.color='var(--color-muted)'"
            >
              <svg
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                <path d="M9 18c-4.51 2-5-2-7-2" />
              </svg>
              {translations.projects.viewOnGitHub}
            </a>
          </div>
        )
      })
    }
  </div>
</section>
