---
import MetricCard from '../ui/MetricCard.astro'
import type { Locale } from '@/i18n/translations'
import { getTranslations } from '@/i18n/translations'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const translations = getTranslations(locale)

const heroMetrics = [
  translations.hero.metrics.deploy,
  translations.hero.metrics.perf,
  translations.hero.metrics.mttd,
]
---

<section
  id="hero"
  style="min-height: 100svh; display: flex; flex-direction: column; justify-content: center; padding: 7rem 1.5rem 5rem; max-width: 1024px; margin: 0 auto;"
>
  <div class="reveal" style="display: flex; flex-direction: column; gap: 1.5rem;">
    <!-- Location badge -->
    <div>
      <span
        style="display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.9rem; border-radius: 9999px; border: 1px solid var(--color-border); background-color: var(--color-surface); font-size: 0.8rem; color: var(--color-muted); font-weight: 500;"
      >
        <span style="width: 6px; height: 6px; border-radius: 50%; background-color: #22c55e; display: inline-block;"></span>
        {translations.hero.location}
      </span>
    </div>

    <!-- Main heading -->
    <div style="display: flex; flex-direction: column; gap: 0.75rem;">
      <h1
        style="font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 700; color: var(--color-text); margin: 0; line-height: 1.1; letter-spacing: -0.03em;"
      >
        Senior Frontend
        <br />
        <span style="color: var(--color-accent);">Engineer</span>
      </h1>
      <p
        style="font-size: clamp(1.1rem, 2.5vw, 1.35rem); color: var(--color-muted); margin: 0; font-weight: 400; max-width: 560px; line-height: 1.5;"
      >
        {translations.hero.subtagline}
      </p>
    </div>

    <!-- Metrics row -->
    <div
      style="display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1rem;"
    >
      {heroMetrics.map((metric) => <MetricCard value={metric.value} label={metric.label} />)}
    </div>

    <!-- CTA -->
    <div style="margin-top: 0.5rem;">
      <a
        href="#contact"
        style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 2rem; background-color: var(--color-accent); color: #fff; font-weight: 600; font-size: 0.95rem; border-radius: 0.5rem; text-decoration: none; transition: opacity 0.2s ease; letter-spacing: 0.01em;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        {translations.hero.cta}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>
