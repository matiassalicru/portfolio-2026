---
import '../styles/global.css'
import { Font } from 'astro:assets'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title id="page-title">404 — Page not found · Matias Salicru</title>
    <meta
      name="description"
      content="The page you're looking for doesn't exist or has moved."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-sans" preload />
  </head>
  <body
    style="min-height: 100svh; display: flex; align-items: center; justify-content: center; padding: 2rem;"
  >
    <main
      style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem; text-align: center; max-width: 560px;"
    >
      <div
        style="font-size: clamp(6rem, 18vw, 10rem); font-weight: 700; line-height: 1; letter-spacing: -0.05em; color: var(--color-accent); user-select: none;"
      >
        404
      </div>
      <h1
        id="heading"
        style="font-size: clamp(1.75rem, 4vw, 2.25rem); font-weight: 700; color: var(--color-text); margin: 0; letter-spacing: -0.02em;"
      >
        Page not found
      </h1>
      <p
        id="subtitle"
        style="font-size: 1.05rem; color: var(--color-muted); margin: 0; line-height: 1.6; min-height: 1.6em;"
      >
        This page didn't make it past code review.
      </p>
      <a
        id="back-link"
        href="/en/"
        style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 2rem; background-color: var(--color-accent); color: #fff; font-weight: 600; font-size: 0.95rem; border-radius: 0.5rem; text-decoration: none; transition: opacity 0.2s ease; letter-spacing: 0.01em; margin-top: 0.5rem;"
        onmouseover="this.style.opacity='0.85'"
        onmouseout="this.style.opacity='1'"
      >
        <span aria-hidden="true">←</span>
        <span id="back-link-label">Back home</span>
      </a>
    </main>

    <script is:inline>
      ;(function () {
        var pathname = window.location.pathname
        var isSpanish =
          pathname === '/es' ||
          pathname === '/es/' ||
          pathname.startsWith('/es/')

        var englishPhrases = [
          "This page didn't make it past code review.",
          '`undefined` is not a page.',
          'Looks like this URL got garbage-collected.',
          'git blame says this was never here.',
          'Stack trace unavailable. Try the homepage.',
          'This route is missing its handler.',
          '404: still better than a runtime error.',
          'The page you requested was deprecated in v2.',
          'No handler found for this path. And no stack trace either.',
        ]

        var spanishPhrases = [
          'Esta página no compila.',
          'Parece que el link se lo llevó el garbage collector.',
          '`undefined` no es una página, loco.',
          'Este URL se mudó sin dejar dirección.',
          '404: mejor que un runtime error.',
          'Este endpoint se fue a tomar mate.',
          'Acá no hay nada. Ni un `<div>`.',
          'git blame dice que esto nunca existió.',
          'Esta ruta quedó deprecada en la v2.',
        ]

        var phrases = isSpanish ? spanishPhrases : englishPhrases
        var randomPhrase =
          phrases[Math.floor(Math.random() * phrases.length)]

        document.getElementById('subtitle').textContent = randomPhrase

        if (!isSpanish) return

        document.documentElement.lang = 'es'
        document.getElementById('page-title').textContent =
          '404 — Página no encontrada · Matias Salicru'
        document.getElementById('heading').textContent = 'Página no encontrada'
        document.getElementById('back-link-label').textContent =
          'Volver al inicio'
        document.getElementById('back-link').href = '/es/'
      })()
    </script>
  </body>
</html>
